@startuml MIE-Decoder Data Flow
!theme plain
scale max 4000*4000
title MIE-Decoder v2.0 - Data Flow (Rust + Python)

' ============================================================================
'  This diagram describes the behavior shared by both implementations.
'  Module/function names are Rust where they differ; the Python equivalents
'  follow the correspondence in docs/ARCHITECTURE.md section 1.
' ============================================================================

|CLI|
start
:Parse CLI arguments\n(decode / count / dump);
:Load TOML config\n(config::load_config);
:Merge CLI overrides\n(config::with_overrides);
:Configure logging\n(log::set_global_level);

|Output Safety|
:Resolve output path;
if (input == output\n(paths_refer_to_same_file)?) then (yes)
  :Raise <b>MieInputOutputCollisionError</b>\n(L2-WRT-016);
  :Exit 1;
  stop
endif
if (output exists and --no-clobber?) then (yes)
  :Raise <b>MieClobberRefusedError</b>\n(L2-WRT-014);
  :Exit 1;
  stop
endif
:Open <stem>.<pid>.tmp for writing\n(<b>AtomicCsvFile</b>);

|Sync|
:mmap input file (read-only, ACCESS_READ);
:sync::find_first_record(data, ...);
note right
  Scan from offset 0, 2-byte steps, <=64 KB
  for a record whose Type Word AND the
  next record's Type Word both validate
  (two-record look-ahead).
end note

if (Valid header found?) then (yes)
  :detect_timestamp_format()\nIRIG (3 words) vs Standard (2 words);
else (no)
  :sync::diagnose_header_scan_failure();
  switch (Cause?)
  case (homogeneous payload)
    :Raise <b>MieHomogeneousPayloadError</b>;
    :Exit 2;
  case (first record truncated)
    :Raise <b>MieFirstRecordTruncatedError</b>;
    :Exit 1;
  case (no valid records)
    :Raise <b>MieNoValidRecordsError</b>;
    :Exit 2;
  endswitch
  :discard AtomicCsvFile (unlink tmp);
  stop
endif

|Reader|
repeat
  :sync::validate_record()\nshape probe + look-ahead\n+ homogeneity check;

  if (Valid?) then (no)
    |Sync|
    :sync::recover_sync()\nscan forward in 2-byte steps;
    if (Recovered?) then (no)
      :Raise <b>MieUnrecoverableSyncLossError</b>\n(terminal Err - iterator ends);

      if (--allow-partial?) then (yes)
        |Output Safety|
        :commit_as_partial()\nrename tmp to <stem>.partial.csv;
        :Log summary + EXIT-005;
        :Exit 0;
        stop
      else (no)
        |Output Safety|
        :discard()\nunlink tmp;
        :Exit 3;
        stop
      endif
    endif
    :Log WARN "sync recovered at offset ...";
    :Resume at recovered offset;
    |Reader|
  endif

  :Decode Type Word\n(bits 0-6: type, bit 7: bus,\n bits 8-13: WC, bit 14: error);

  if (Type == 0x20 (SPURIOUS_DATA)?) then (yes)
    :Extract raw bus words\n(no Command Word);
    :Assign decoder-internal code:\n  0x2000 (continuation)\n  0x2001 (standalone);
    :prev_was_error = false;
  elseif (Bit 14 (ERROR) set?) then (yes)
    :Decode Command Word(s);
    :Extract truncated payload;
    :Extract Error Word\n(last word of record);
    :Validate vs is_known_error_code();
    :prev_was_error = true;
    note right
      Errored records SKIP structural
      invariants (payload truncated
      by definition).
    end note
  else (normal)
    :Decode timestamp (IRIG or Standard);
    :Decode Command Word(s);
    :classify_message_format()\nreturns 1 of 10 normal formats;

    |Structural Invariants|
    :validate_structural_invariants()\nL2-SYN-020..025;
    if (Severity?) then (Reject)
      :Raise <b>MieRecordError</b>;
    else (AnomalyWarn / OK)
      :Log WARN on AnomalyWarn,\nkeep record;
    endif
    |Reader|
    :Extract payload\n(cmd2, status, status2, data);
    :validate_post_extract_invariants();
    :prev_was_error = false;
  endif

  :Compute per-RT/MSG DELTA\n(non-monotonic timestamp causes WARN);

  |Filter|
  :filter::should_emit(msg)\ninclude AND NOT exclude\n(type/RT/bus/SA);
  if (Emit?) then (yes)

    |Writer|
    :message_to_row()\nreturns Row (DDC vendor column order);
    if (msg.is_error or msg.is_spurious) then (yes)
      if (error_mode == SEPARATE\nand stdout is file?) then (yes)
        :Append to errors writer\n(<stem>.<pid>.errors.tmp);
      else (INLINE / stdout)
        :Append to main writer\n(ERROR + ERROR_CODE columns set);
      endif
    else (no)
      :Append to main writer;
    endif
    :Streaming write - no buffering\n(constant memory);

    |Reader|
  endif
repeat while (more records?) is (yes)
-> no;

|Output Safety|
:flush + fsync writers;
:commit(): rename tmp to <stem>.csv\n(and <stem>_errors.csv in separate mode);

|CLI|
:Log INFO summary line\n(L1-EXIT-005 exit class);
note right
  Format:
    "decoded N records (M errors,
     K sync recoveries) to <output>
     [exit_class=<class>]"
  Exit class drives process exit code:
    0: complete / partial-recovered /
        broken-pipe
    1: record or usage error
    2: no records / homogeneous payload
    3: partial-unrecoverable
end note

:Exit with class code;
stop

@enduml
